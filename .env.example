# Vercel Environment Variables
# Set these in: Vercel Dashboard > Your Project > Settings > Environment Variables
# NEVER commit real values to this file or any file in git

# Your Binance API credentials (Spot Trading permission only, no withdrawals)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Set to "true" to use Binance Testnet (recommended to start)
# Set to "false" only when you are ready for live trading
BINANCE_TESTNET=true

# A random secret string shared between Vercel and GitHub Actions
# This prevents unauthorized calls to your /api/bot/run endpoint
# Generate one: openssl rand -hex 32
BOT_SECRET=generate-a-random-string-here

# GitHub Actions Secrets
# Set these in: GitHub Repo > Settings > Secrets > Actions

# APP_URL=https://your-app-name.vercel.app
# BOT_SECRET=same-value-as-vercel-above