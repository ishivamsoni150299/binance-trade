{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/binancetradesaas/browser",
  "rewrites": [
    { "source": "/api/bot/run", "destination": "/api/bot/run" },
    { "source": "/api/market/klines", "destination": "/api/market/klines" },
    { "source": "/api/wallet/balances", "destination": "/api/wallet/balances" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-Bot-Secret" }
      ]
    }
  ]
}
